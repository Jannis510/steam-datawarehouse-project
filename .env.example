POSTGRES_CONTAINER_NAME=dwh-postgres
POSTGRES_DB=dwh
POSTGRES_USER=dwh
POSTGRES_PASSWORD=dwh
POSTGRES_PORT=5432
POSTGRES_HOST=postgres
POSTGRES_DUMP_FILE=/dumps/dwh_data.dump
POSTGRES_SMOKE_TEST=1

# Daily at 00:00 UTC.
ETL_CRON_SCHEDULE=0 0 * * *
ETL_CRON_SCRIPT=/app/scripts/steam_etl_incremental.py

# 0 means "no limit".
ETL_APPS_LIMIT=0
ETL_STEAMSPY_LIMIT=0
# Set to 1 to skip the news phase.
ETL_SKIP_NEWS=0
# Steam defaults are 100 pages x 100 items per page.
NEWS_MAX_PAGES=100
NEWS_PAGE_SIZE=100
# Delay between app requests in seconds.
NEWS_SLEEP_S=0
COMMIT_EVERY_APPS=1
LOG_EVERY=1
LOG_CONFLICTS_LIMIT=20
TZ=UTC

PGADMIN_CONTAINER_NAME=dwh-pgadmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

SUPERSET_CONTAINER_NAME=dwh-superset
SUPERSET_PORT=8088
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_SECRET_KEY=change-me
SUPERSET_DB_USER=superset
SUPERSET_DB_PASSWORD=superset
SUPERSET_DB_NAME=superset
SUPERSET_LOAD_EXAMPLES=false
SUPERSET_IMPORT_DASHBOARDS=1
SUPERSET_IMPORT_DIR=/app/imports
SUPERSET_IMPORT_WORK_DIR=/tmp/imports
SUPERSET_IMPORT_OVERWRITE=1
SUPERSET_IMPORT_MARKER=/app/superset_home/.dashboards_imported
SUPERSET_IMPORT_SQLALCHEMY_URI=
SUPERSET_IMPORT_FORCE_URI=0
DWH_SQLALCHEMY_URI=postgresql+psycopg2://dwh:dwh@postgres:5432/dwh
SUPERSET_CONFIG_PATH=/app/superset_config.py
