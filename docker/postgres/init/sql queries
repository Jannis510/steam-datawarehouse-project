WITH latest_run AS (
  SELECT MAX(t.ts) AS run_ts
  FROM dwh.fact_steamspy_stats f
  JOIN dwh.dim_timestamp t ON t.timestamp_id = f.timestamp_id
),
latest_steamspy AS (
  SELECT
    f.app_id,
    f.ccu,
    f.owners_max,
    f.positive,
    f.negative,
    f.userscore,
    lr.run_ts AS fetched_at
  FROM dwh.fact_steamspy_stats f
  JOIN dwh.dim_timestamp t ON t.timestamp_id = f.timestamp_id
  JOIN latest_run lr ON t.ts = lr.run_ts
),
news_30d AS (
  SELECT
    n.app_id,
    COUNT(*) AS news_count_30d
  FROM dwh.fact_news n
  JOIN dwh.dim_timestamp t ON t.timestamp_id = n.timestamp_id
  WHERE t.ts >= NOW() - INTERVAL '30 days'
  GROUP BY n.app_id
)
SELECT
  a.app_id,
  a.app_name,
  s.ccu,
  COALESCE(n.news_count_30d, 0) AS news_count_30d,
  CASE
    WHEN COALESCE(n.news_count_30d, 0) = 0 THEN NULL
    ELSE (s.ccu::numeric / n.news_count_30d)
  END AS ccu_per_news_30d,
  s.fetched_at
FROM latest_steamspy s
JOIN dwh.dim_app a ON a.app_id = s.app_id
LEFT JOIN news_30d n ON n.app_id = s.app_id
WHERE s.ccu IS NOT NULL
ORDER BY ccu_per_news_30d DESC NULLS LAST
LIMIT 50;



WITH latest_run AS (
  SELECT MAX(t.ts) AS run_ts
  FROM dwh.fact_steamspy_stats f
  JOIN dwh.dim_timestamp t ON t.timestamp_id = f.timestamp_id
),
latest_steamspy AS (
  SELECT f.app_id, f.ccu
  FROM dwh.fact_steamspy_stats f
  JOIN dwh.dim_timestamp t ON t.timestamp_id = f.timestamp_id
  JOIN latest_run lr ON t.ts = lr.run_ts
),
news_30d AS (
  SELECT n.app_id, COUNT(*) AS news_count_30d
  FROM dwh.fact_news n
  JOIN dwh.dim_timestamp t ON t.timestamp_id = n.timestamp_id
  WHERE t.ts >= NOW() - INTERVAL '30 days'
  GROUP BY n.app_id
)
SELECT
  a.app_id,
  a.app_name,
  s.ccu
FROM latest_steamspy s
JOIN dwh.dim_app a ON a.app_id = s.app_id
LEFT JOIN news_30d n ON n.app_id = s.app_id
WHERE COALESCE(n.news_count_30d, 0) = 0
ORDER BY s.ccu DESC NULLS LAST
LIMIT 50;



WITH latest_run AS (
  SELECT MAX(t.ts) AS run_ts
  FROM dwh.fact_steamspy_stats f
  JOIN dwh.dim_timestamp t ON t.timestamp_id = f.timestamp_id
),
latest_steamspy AS (
  SELECT f.app_id, f.ccu
  FROM dwh.fact_steamspy_stats f
  JOIN dwh.dim_timestamp t ON t.timestamp_id = f.timestamp_id
  JOIN latest_run lr ON t.ts = lr.run_ts
),
news_7d AS (
  SELECT n.app_id, COUNT(*) AS news_count_7d
  FROM dwh.fact_news n
  JOIN dwh.dim_timestamp t ON t.timestamp_id = n.timestamp_id
  WHERE t.ts >= NOW() - INTERVAL '7 days'
  GROUP BY n.app_id
)
SELECT
  a.app_id,
  a.app_name,
  COALESCE(s.ccu, 0) AS ccu,
  n.news_count_7d,
  CASE
    WHEN s.ccu IS NULL OR s.ccu = 0 THEN NULL
    ELSE (n.news_count_7d::numeric / s.ccu)
  END AS news_per_ccu_7d
FROM news_7d n
JOIN dwh.dim_app a ON a.app_id = n.app_id
LEFT JOIN latest_steamspy s ON s.app_id = n.app_id
ORDER BY news_per_ccu_7d DESC NULLS LAST
LIMIT 50;